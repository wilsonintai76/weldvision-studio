# WeldSim Studio — Cloudflare Pages Environment
#
# This app uses Cloudflare Workers AI (no API key needed).
# The AI binding is declared in wrangler.toml under [ai].
#
# For local development, use .dev.vars (gitignored) for any secrets.
# For production, add secrets via:
#   wrangler pages secret put MY_SECRET
#
# APP_URL: The Cloudflare Pages URL where this app is hosted.
# Set this in the Cloudflare Pages dashboard under Settings > Environment Variables.
APP_URL="https://weldsim-studio.pages.dev"
